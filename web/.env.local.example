# CloudSearch web — environment configuration.
# Copy to .env.local for local development.

# Base URL of the Go API (port 8080). The browser NEVER calls this directly;
# the Next.js route handlers (app/api/search, app/api/stats) proxy to it.
BACKEND_URL=http://localhost:8080

# Optional: build/version tag shown in the top bar and footer (client-visible).
# NEXT_PUBLIC_BUILD_TAG=v0.1.0
